<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundColor"
    tools:context=".GestionOrdenesActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primaryColor">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="Gestión de Órdenes"
            app:titleTextColor="@color/white"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:navigationIconTint="@color/white" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- New Order Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nueva Orden"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/primaryColor"
                        android:layout_marginBottom="12dp"/>

                    <EditText
                        android:id="@+id/etFecha"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Fecha"
                        android:focusable="false"
                        android:clickable="true"
                        android:inputType="date" />

                    <Spinner
                        android:id="@+id/spClientes"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="8dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/dividerColor"
                        android:layout_marginVertical="12dp"/>

                    <Spinner
                        android:id="@+id/spProductos"
                        android:layout_width="match_parent"
                        android:layout_height="48dp" />

                    <EditText
                        android:id="@+id/etCantidad"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Cantidad"
                        android:inputType="number"
                        android:layout_marginTop="8dp"/>

                    <Button
                        android:id="@+id/btnAgregarProducto"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Añadir al Resumen"
                        android:layout_marginTop="8dp"
                        style="@style/Widget.MaterialComponents.Button.TextButton"/>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvDetallesActuales"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="50dp"
                        android:nestedScrollingEnabled="false" />

                    <TextView
                        android:id="@+id/tvTotalGeneral"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total: $0.00"
                        android:textStyle="bold"
                        android:layout_gravity="end"
                        android:layout_marginTop="8dp"
                        android:textColor="@color/textPrimary"/>

                    <Button
                        android:id="@+id/btnGuardarOrden"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Registrar Orden"
                        android:layout_marginTop="16dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Historial de Órdenes"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvOrdenesHistorial"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />

            <TextView
                android:id="@+id/tvOrdenesVacias"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No hay órdenes registradas."
                android:gravity="center"
                android:padding="24dp"
                android:visibility="gone"
                android:textStyle="italic"/>

            <!-- Hidden button to avoid code crashes if it expects it -->
            <Button android:id="@+id/btnRegresarAlMenu" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>