<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="?attr/colorSurface"> <!-- Cambia dinámicamente según el modo -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <LinearLayout
            android:id="@+id/lytInfo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginEnd="8dp">

            <!-- Nombre (Texto Principal Adaptativo) -->
            <TextView
                android:id="@+id/tvNombre"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Juan Pérez"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="?android:attr/textColorPrimary"/>

            <!-- Correo (Texto Secundario Adaptativo) -->
            <TextView
                android:id="@+id/tvCorreo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="juan@correo.com"
                android:textSize="14sp"
                android:layout_marginTop="4dp"
                android:textColor="?android:attr/textColorSecondary"/>

            <!-- Teléfono (Texto Secundario Adaptativo) -->
            <TextView
                android:id="@+id/tvTelefono"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="6123-4567"
                android:textSize="14sp"
                android:layout_marginTop="2dp"
                android:textColor="?android:attr/textColorSecondary"/>

            <!-- Dirección (Texto Secundario Adaptativo) -->
            <TextView
                android:id="@+id/tvDireccion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Vía España, Panamá"
                android:textSize="14sp"
                android:layout_marginTop="2dp"
                android:textColor="?android:attr/textColorSecondary"/>
        </LinearLayout>

        <!-- Botón Eliminar (Usa el color de error definido en tus temas) -->
        <ImageButton
            android:id="@+id/btnEliminar"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Eliminar cliente"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            app:tint="?attr/colorError" />

    </LinearLayout>

</androidx.cardview.widget.CardView>