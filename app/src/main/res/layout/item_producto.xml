<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="?attr/colorSurface">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">
        <!-- Contenedor de la información del producto -->
        <LinearLayout
            android:id="@+id/lytInfoProducto"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginEnd="8dp">
            <!-- Nombre del Producto -->
            <TextView
                android:id="@+id/tvNombreProducto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nombre del Producto"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="?android:attr/textColorPrimary"/>

            <!-- Descripción-->
            <TextView
                android:id="@+id/tvDescripcionProducto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Descripción breve del producto aquí"
                android:textSize="14sp"
                android:layout_marginTop="4dp"
                android:textColor="?android:attr/textColorSecondary"/>

            <!-- Fila para Precio y Stock -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="6dp"
                android:gravity="center_vertical">
                <!-- Precio -->
                <TextView
                    android:id="@+id/tvPrecioProducto"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$0.00"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorPrimary"/>
                <!-- Espacio intermedio -->
                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />
                <!-- Stock Disponible -->
                <TextView
                    android:id="@+id/tvStockProducto"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Stock: 12 u."
                    android:textSize="13sp"
                    android:textStyle="italic"
                    android:textColor="?android:attr/textColorSecondary"
                    android:layout_marginEnd="4dp"/>
            </LinearLayout>
        </LinearLayout>
        <!-- Botón Eliminar -->
        <ImageButton
            android:id="@+id/btnEliminarProducto"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Eliminar producto"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            app:tint="?attr/colorError" />
    </LinearLayout>
</androidx.cardview.widget.CardView>