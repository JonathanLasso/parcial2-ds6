<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Contenedor de la información del producto -->
        <LinearLayout
            android:id="@+id/lytInfoProducto"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginEnd="8dp">

            <!-- Nombre del Producto -->
            <TextView
                android:id="@+id/tvNombreProducto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nombre del Producto"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#333333"/>

            <!-- Descripción -->
            <TextView
                android:id="@+id/tvDescripcionProducto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Descripción breve del producto aquí"
                android:textSize="14sp"
                android:layout_marginTop="2dp"
                android:textColor="#666666"/>

            <!-- Precio -->
            <TextView
                android:id="@+id/tvPrecioProducto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$0.00"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#2E7D32"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Botón Eliminar (Se mantiene igual al de cliente) -->
        <ImageButton
            android:id="@+id/btnEliminarProducto"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Eliminar producto"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            app:tint="#D32F2F" />

    </LinearLayout>

</androidx.cardview.widget.CardView>