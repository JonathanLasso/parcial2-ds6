<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="?attr/colorSurface">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">
        <!-- ENCABEZADO: Info de la Orden y Botón Eliminar -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_toStartOf="@id/btnEliminar"
                android:orientation="vertical">
                <!-- ID de la Orden -->
                <TextView
                    android:id="@+id/tvHistorialIdOrden"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Orden #1"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textStyle="bold"
                    android:textSize="16sp" />
                <!-- Fecha -->
                <TextView
                    android:id="@+id/tvHistorialFecha"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fecha: 2026-07-02"
                    android:textSize="12sp"
                    android:textColor="?android:attr/textColorSecondary" />
            </LinearLayout>
            <!-- Botón Eliminar -->
            <ImageButton
                android:id="@+id/btnEliminar"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_alignParentEnd="true"
                android:layout_alignParentTop="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Eliminar orden"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                app:tint="?attr/colorError" />
        </RelativeLayout>
        <!-- Línea divisoria -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?android:attr/textColorSecondary"
            android:alpha="0.15"/>
        <!-- Contenedor de productos -->
        <LinearLayout
            android:id="@+id/containerProductos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginVertical="4dp">
            <!-- Ejemplo de un producto -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="4dp">
                <TextView
                    android:id="@+id/tvProdNombreCant"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2x Hamburguesa Clásica"
                    android:textColor="?android:attr/textColorPrimary"/>
                <TextView
                    android:id="@+id/tvProdSubtotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="$15.00"
                    android:textColor="?android:attr/textColorPrimary"/>
            </RelativeLayout>
        </LinearLayout>
        <!-- Línea divisoria -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="?android:attr/textColorSecondary"
            android:alpha="0.15"
            android:layout_marginVertical="8dp" />
        <!-- Estado y Total General -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <!-- Estado de la Orden -->
            <TextView
                android:id="@+id/tvHistorialEstado"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Entregado"
                android:textStyle="bold"
                android:textSize="14sp"
                android:textColor="?attr/colorPrimary"
                android:singleLine="true"
                android:ellipsize="end"
                android:layout_marginEnd="8dp" />
            <!-- Contenedor del Total -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="bottom">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Total: "
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:textColor="?android:attr/textColorPrimary"
                    android:layout_marginEnd="4dp"/>
                <!-- Valor total de la orden -->
                <TextView
                    android:id="@+id/tvHistorialTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$0.00"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:textColor="?attr/colorPrimary" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>